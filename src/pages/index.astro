---
const base = import.meta.env.BASE_URL;
const pathWithBase = (path: string) => `${base}${base.endsWith('/') ? '' : '/'}${path}`;
const zhStart = pathWithBase('zh/guides/overview/');
const enStart = pathWithBase('en/guides/overview/');
const jaStart = pathWithBase('ja/guides/overview/');
const demoHref =
  'https://github.com/2023Anita/openai-agents-medical-research-guide/blob/main/examples/medical_research_agent_demo.py';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>OpenAI Agents SDK for Medical Research</title>
    <meta
      name="description"
      content="A multilingual, safety-first course for building medical research assistants with the OpenAI Agents SDK."
    />
    <meta property="og:image" content={pathWithBase('og-image.png')} />
    <link rel="icon" href={pathWithBase('favicon.png')} />
  </head>
  <body>
    <main class="landing-shell">
      <nav class="topbar" aria-label="Primary">
        <a class="brand" href={pathWithBase('')}>
          <img src={pathWithBase('logo.png')} alt="" />
          <span>OpenAI Agents SDK for Medical Research</span>
        </a>
        <div class="language-row" aria-label="Languages">
          <a href={zhStart}>中文</a>
          <a href={enStart}>English</a>
          <a href={jaStart}>日本語</a>
        </div>
      </nav>

      <section class="hero">
        <p class="eyebrow">Multilingual course · Python · Safety-first agents</p>
        <h1>Build medical research agents with clarity, boundaries, and taste.</h1>
        <p class="lede">
          A premium, practical guide for doctors, researchers, and AI builders who want to understand
          the OpenAI Agents SDK through one focused project: a medical research assistant that can use
          tools, structure outputs, remember context, orchestrate specialist agents, enforce guardrails,
          and trace every step.
        </p>
        <div class="hero-actions">
          <a class="button primary" href={zhStart}>Start learning</a>
          <a class="button secondary" href={demoHref}>View demo code</a>
        </div>
      </section>

      <section class="cards" aria-label="Course highlights">
        <article>
          <span>01</span>
          <h2>Agent Workflow</h2>
          <p>
            Learn how Agent, Runner, Tools, Sessions, multi-agent orchestration, Guardrails, and Tracing
            fit into one coherent loop.
          </p>
        </article>
        <article>
          <span>02</span>
          <h2>Medical Research Safety</h2>
          <p>
            Keep the assistant inside research support: study design, literature planning, statistical
            drafts, and manuscript structure, never diagnosis or treatment advice.
          </p>
        </article>
        <article>
          <span>03</span>
          <h2>Seamless Languages</h2>
          <p>
            Read the same course structure in Chinese, English, or Japanese with matching chapter slugs
            for smooth switching.
          </p>
        </article>
      </section>

      <section class="course-map" aria-label="Course map">
        <div>
          <p class="eyebrow">Course map</p>
          <h2>Seven chapters, one reusable mental model.</h2>
        </div>
        <ol>
          <li>Agent + Runner</li>
          <li>Tools</li>
          <li>Structured Output</li>
          <li>Sessions</li>
          <li>Multi-agent</li>
          <li>Guardrails</li>
          <li>Tracing</li>
        </ol>
      </section>
    </main>
  </body>
</html>

<style>
  :global(html) {
    background: #f7faf9;
    color: #15211f;
    font-family:
      Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
  }

  :global(body) {
    margin: 0;
  }

  .landing-shell {
    min-height: 100vh;
    background:
      linear-gradient(180deg, rgba(247, 250, 249, 0.96), rgba(238, 246, 244, 0.92)),
      radial-gradient(circle at 70% 10%, rgba(35, 134, 118, 0.12), transparent 32%);
  }

  .topbar,
  .hero,
  .cards,
  .course-map {
    width: min(1120px, calc(100% - 40px));
    margin: 0 auto;
  }

  .topbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    padding: 28px 0;
  }

  .brand {
    align-items: center;
    color: #15211f;
    display: inline-flex;
    gap: 12px;
    font-weight: 720;
    text-decoration: none;
  }

  .brand img {
    border-radius: 6px;
    height: 54px;
    object-fit: contain;
    width: 54px;
  }

  .language-row {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
  }

  .language-row a,
  .button {
    border: 1px solid rgba(21, 33, 31, 0.14);
    border-radius: 999px;
    color: #15211f;
    font-weight: 650;
    padding: 10px 14px;
    text-decoration: none;
  }

  .hero {
    padding: 96px 0 72px;
  }

  .eyebrow {
    color: #287b70;
    font-size: 0.84rem;
    font-weight: 760;
    letter-spacing: 0;
    margin: 0 0 16px;
    text-transform: uppercase;
  }

  h1 {
    font-size: clamp(3rem, 8vw, 7rem);
    letter-spacing: 0;
    line-height: 0.94;
    margin: 0;
    max-width: 980px;
  }

  .lede {
    color: #465a55;
    font-size: clamp(1.05rem, 2vw, 1.35rem);
    line-height: 1.7;
    max-width: 820px;
    margin: 28px 0 0;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: 34px;
  }

  .button {
    display: inline-flex;
    align-items: center;
    min-height: 24px;
    padding: 13px 18px;
  }

  .button.primary {
    background: #15211f;
    color: #ffffff;
  }

  .button.secondary {
    background: rgba(255, 255, 255, 0.68);
  }

  .cards {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 16px;
    padding-bottom: 54px;
  }

  article {
    background: rgba(255, 255, 255, 0.74);
    border: 1px solid rgba(21, 33, 31, 0.1);
    border-radius: 8px;
    padding: 24px;
  }

  article span {
    color: #287b70;
    font-size: 0.82rem;
    font-weight: 760;
  }

  article h2,
  .course-map h2 {
    letter-spacing: 0;
    margin: 12px 0;
  }

  article p {
    color: #536762;
    line-height: 1.62;
    margin: 0;
  }

  .course-map {
    align-items: start;
    border-top: 1px solid rgba(21, 33, 31, 0.12);
    display: grid;
    gap: 28px;
    grid-template-columns: 1fr 1.1fr;
    padding: 48px 0 80px;
  }

  .course-map ol {
    display: grid;
    gap: 10px;
    list-style: decimal-leading-zero;
    margin: 0;
    padding-left: 24px;
  }

  .course-map li {
    border-bottom: 1px solid rgba(21, 33, 31, 0.1);
    font-weight: 650;
    padding: 10px 0;
  }

  @media (max-width: 760px) {
    .topbar,
    .course-map {
      display: block;
    }

    .language-row {
      margin-top: 18px;
    }

    .hero {
      padding-top: 56px;
    }

    .cards {
      grid-template-columns: 1fr;
    }
  }
</style>
